DATABASE_URL=postgresql://opendiary:opendiary@localhost:5432/opendiary
JWT_SECRET=change_this_to_a_long_random_string
UPLOADS_DIR=./uploads
# 1 to mark the session cookie Secure (serving over HTTPS), 0 for plain HTTP
HTTPS=0
# max request size — effectively the largest accepted photo
BODY_SIZE_LIMIT=25M
# Resend transactional email (https://resend.com) for email verification
RESEND_API_KEY=re_xxxxxxxx
MAIL_FROM=opendiary@yourdomain
# public base URL used to build verification links in emails
PUBLIC_APP_URL=https://opendiary.yourdomain
